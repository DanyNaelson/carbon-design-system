{
  "name": "@yourorg/design-system",
  "version": "0.1.0",
  "description": "Design system built on Carbon Design System with custom tokens and theme overrides",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": {
      "import": "./dist/styles/index.css"
    }
  },
  "files": ["dist"],
  "sideEffects": ["*.css", "*.scss"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@carbon/react": "^1.71.0",
    "@carbon/themes": "^11.43.0",
    "@carbon/type": "^11.33.0",
    "@carbon/colors": "^11.28.0",
    "@carbon/layout": "^11.25.0"
  },
  "devDependencies": {
    "@storybook/react": "^8.4.0",
    "storybook": "^8.4.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sass": "^1.80.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
